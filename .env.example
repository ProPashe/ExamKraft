# ExamKraft Environment Variables
# Copy this file to .env and fill in your values.
# ⚠️  Never commit your .env file — it is in .gitignore

# ── Server ─────────────────────────────────────────────────────
# Port the Express server listens on (defaults to 3000)
PORT=3000

# Node environment: "development" or "production"
NODE_ENV=development

# The public URL of the frontend (used for CORS and Paynow return URLs)
FRONTEND_URL=http://localhost:3000

# ── Paynow Payment Gateway ─────────────────────────────────────
# Obtain from your Paynow merchant dashboard → Integration Keys
PAYNOW_INTEGRATION_ID=your_integration_id_here
PAYNOW_INTEGRATION_KEY=your_integration_key_here

# ── Firebase (Server / Admin SDK) ──────────────────────────────
# Your Firebase Project ID (found in Firebase Console → Project Settings)
FIREBASE_PROJECT_ID=your_firebase_project_id

# Optional: Path to a service account JSON for local Admin SDK authentication.
# In production, use Application Default Credentials (ADC) instead.
# GOOGLE_APPLICATION_CREDENTIALS=./path/to/service-account.json

# ── Admin ──────────────────────────────────────────────────────
# The Google account email that receives admin privileges on first sign-in
ADMIN_EMAIL=your_admin_email@gmail.com

# Same email exposed to the Vite frontend (prefix VITE_ required)
VITE_ADMIN_EMAIL=your_admin_email@gmail.com

# ── Gemini AI ──────────────────────────────────────────────────
# Gemini API key — obtain from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
